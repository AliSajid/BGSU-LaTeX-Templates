  series = {Developing Qualitative Inquiry},
  publisher = {Routledge},
  address = {New York},
  abstract = {"Poetry as Method examines the use of poetry as a form of research, representation, and method used by researchers, practitioners, and students from across the social sciences and humanities. The book maps out what doing and critiquing poetry as/in/for research entails. It begins with a discussion of the power of poetry, moving to the goals and kinds of projects that are best suited for poetic inquiry, then describing the process and craft of that writing. Crucially, it answer questions about how we can use poetry to represent research and the research process"--},
