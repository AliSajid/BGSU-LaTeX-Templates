@article{bashirUnderstandingContributingFactors2018,
  title = {Understanding {{Contributing Factors}} to {{Cultural Identity}} of {{Pakistani Americans}}},
  author = {Bashir, Huma A. and Tang, Mei},
  year = 2018,
  journal = {Journal of Multicultural Counseling and Development},
  volume = {46},
  number = {4},
  pages = {264--282},
  issn = {2161-1912},
  doi = {10.1002/jmcd.12114},
  urldate = {2024-03-18},
  abstract = {This qualitative study explores the experiences of 3 generations of Pakistani Americans with an aim to understand the contributing factors to their cultural identity and the meaning of their experiences. The sample consists of 1st-, 1.5-, and 2nd-generation Pakistani Americans. Data were collected via semistructured interviews and a focus group and were analyzed using thematic analysis. Results revealed 5 common themes intertwined across generational groups: awareness of cultural identity differences are situational; sense of loss; positive experience; awareness of 2 cultures; and culture and religion. Implications for counseling Pakistani Americans are discussed. Este estudio cualitativo explora las experiencias de tres generaciones de estadounidenses de origen paquistan\'i, con el objetivo de comprender los factores que contribuyen a su identidad cultural y el significado de sus experiencias. La muestra incluye personas estadounidenses de origen paquistan\'i de primera, 1.5 y segunda generaci\'on. Los datos fueron recopilados a trav\'es de entrevistas semiestructuradas y un grupo de enfoque, y fueron analizados usando el an\'alisis tem\'atico. Los resultados revelaron cinco temas comunes entrelazados a lo largo de grupos generacionales: la conciencia de que las diferencias de identidad cultural son situacionales; el sentimiento de p\'erdida; las experiencias positivas; la conciencia de dos culturas; y la cultura y religi\'on. Se discuten las implicaciones para la consejer\'ia de personas estadounidenses de origen paquistan\'i.},
  copyright = {\copyright{} 2018 American Counseling Association. All rights reserved.},
  langid = {english},
  keywords = {acculturation,aculturacion,construccion de significado,cultural identity,estadounidenses de origen paquistani,estadounidenses musulmanes,generacional,generational,identidad cultural,meaning making,Muslim Americans,Pakistani Americans}
}

