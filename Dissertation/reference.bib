@article{barclayFamilyMemoryIdentity2021,
  title = {Family, {{Memory}}, and {{Identity}}: {{An Introduction}}},
  shorttitle = {Family, {{Memory}}, and {{Identity}}},
  author = {Barclay, Katie and Koefoed, Nina Javette},
  year = 2021,
  month = jan,
  journal = {Journal of Family History},
  volume = {46},
  number = {1},
