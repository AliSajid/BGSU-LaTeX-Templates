@article{dohertyExaminingImpactThird2023,
  title = {Examining the {{Impact}} of a {{Third Culture Kid Upbringing}}: {{Wellbeing}}, {{Attachment}} and {{Ethnic Identity Strength}} in {{Adult Third Culture Kids}}},
  shorttitle = {Examining the {{Impact}} of a {{Third Culture Kid Upbringing}}},
  author = {Doherty, Lucy and Lieu, Jenai and Aledeh, Muhammad and Edwards, Ann-Marie and Kotera, Yasuhiro},
  year = 2023,
  month = aug,
  journal = {Journal of Research in International Education},
  volume = {22},
  number = {2},
  pages = {164--180},
  issn = {1475-2409, 1741-2943},
  doi = {10.1177/14752409231189364},
  urldate = {2023-12-28},
  abstract = {Third Culture Kids (TCK) are generally considered to be children who spend a significant period living outside of their home country but reside only temporarily in one or more host country/ies. TCKs' upbringing, it is argued, may lead to a number of negative psychological outcomes including depression, anxiety, and identity and attachment issues. This quantitative study based on a total of 489 participants compares the self-report responses of adults who had been TCKs with those of non-TCK adults, on the measures of ethnic identity, wellbeing, loneliness, attachment, resilience, and self-concept clarity. Results indicate that TCK adults had a weaker ethnic identity, greater resilience, and were less comfortable forming close relationships than non-TCK adults. Among TCK adults, having siblings was associated with reduced attachment anxiety and greater resilience, while practising a religion was related to increased ethnic identity. Findings indicate the need to raise awareness among parents, teachers, and counsellors about the difficulties that TCKs might face.},
  langid = {english}
}

