@incollection{kaliaBufferingParentchildConflict2022,
  title = {Buffering against Parent-Child Conflict: {{Exploring}} the Role of Biculturalism in the Relationship between South Asian College Students and Their Parents},
  booktitle = {Re/{{Formation}} and Identity: {{The}} Intersectionality of Development, Culture, and Immigration},
  author = {Kalia, Vrinda and Aggarwal, Pankhuri and Raval, Vaishali V.},
  editor = {Johnson, Deborah J. and Chuang, Susan S. and Glozman, Jenny},
  year = 2022,
  pages = {111--133},
  publisher = {Springer International Publishing},
  address = {Cham},
  doi = {10.1007/978-3-030-86426-2_6},
  abstract = {Immigrants around the world learn to navigate different cultural spheres in a multifaceted process that impacts their identity. Those who are able to reconstruct their identity by harmoniously integrating varying cultural frames of reference are also able to experience productive family relationships and positive well-being. In the current study, we explore the protective role of bicultural identity in intergenerational family conflict and overall adjustment among South Asian American emerging adults in the U.S., a highly understudied group. Participants (N = 52) completed self-report measures of bicultural identity, intergenerational conflict, emotion regulation, and adjustment. We found that emerging adults who viewed their South Asian and American cultures as more harmonious reported lower anxiety, and those who viewed their South Asian and American cultures as more blended reported adaptive emotion regulation strategies and fewer academic problems. Moreover, emerging adults who reported having more conflicts with their parents about family expectations and education and career reported higher levels of anxiety, family, and academic problems. Interestingly, bicultural blended emerging adults reported fewer conflicts with their parents about learning their own South Asian language but more conflicts about emphasis on materialism and success. We discuss these findings within broader social, political, and cultural contexts of immigration to the US.},
  isbn = {978-3-030-86426-2}
}

