@article{maiterUnderstandingContextCulture2003,
  title = {Understanding {{Context}} and {{Culture}} in the {{Parenting Approaches}} of {{Immigrant South Asian Mothers}}},
  author = {Maiter, Sarah and George, Usha},
  year = 2003,
  month = nov,
  journal = {Affilia},
  volume = {18},
  number = {4},
