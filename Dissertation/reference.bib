  pages = {115--133},
  publisher = {Springer Netherlands},
  address = {Dordrecht},
  doi = {10.1007/978-94-024-1141-6_6},
  urldate = {2023-09-19},
  abstract = {This study considers migration as a family-based project in which parents as well as their children are involved. As a consequence, we collect data on the relations between generationsrelations between generations, and especially on remittancesremittancesand gifts that circulate between migrants and their offsprings. Differences in intergenerational exchangesintergenerationalintergenerational exchangesexist depending on whether children lived in the country of origincountrycountry of originor whether the family formation occurred after migration and children were born in the country of destination. We present two surveys in which respondents were migrants of the first generation. These surveys show that retirement represents a crucial event in migrant families. The results show that the place where children live is an important factor determining parents' residence after retirement. We also find evidence that when parents remain in the host countryhost countryrather than migrate back to the country of origincountrycountry of origin, intergenerational economic transfers go more often from children to parents.},
  isbn = {978-94-024-1141-6},
  langid = {english}
}

